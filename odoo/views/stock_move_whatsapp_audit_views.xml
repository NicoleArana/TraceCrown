<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_whatsapp_audit_pivot" model="ir.ui.view">
        <field name="name">stock.move.whatsapp.audit.pivot</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="whatsapp_audit_source" type="row"/>
                <field name="inventory_recorded" type="measure"/>
                <field name="inventory_expected" type="measure"/>
            </xpath>
        </field>
    </record>
</odoo>
